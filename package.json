{
  "name": "mcp-notarium",
  "version": "1.0.0",
  "private": true,
  "description": "Unreleased Simplenote MCP prototype. Use @automattic/simplenote-mcp.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --out-dir dist && mkdir -p dist/assets && cp assets/custom-sql-wasm.wasm dist/assets/ && cp assets/custom-sql-wasm.js dist/assets/ && cp assets/custom-sql-wasm-loader.mjs dist/assets/ && cp assets/custom-sql-wasm-loader.d.ts dist/assets/",
    "start": "node dist/index.js",
    "dev": "tsup src/index.ts --format esm --dts --out-dir dist --watch --onSuccess \"node dist/index.js\" --external pino-pretty",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "lint:check-format": "prettier --check \"src/**/*.ts\" \"docs/**/*.md\" \"*.{js,json,md,cjs,mjs}\"",
    "format": "prettier --write \"src/**/*.ts\" \"docs/**/*.md\" \"*.{js,json,md,cjs,mjs}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "print-config-vars": "node dist/index.js --print-config-vars",
    "prepublishOnly": "node -e \"throw new Error('mcp-notarium is an unreleased prototype; use @automattic/simplenote-mcp')\""
  },
  "bin": {
    "mcp-notarium": "dist/index.js"
  },
  "keywords": [
    "mcp",
    "simplenote",
    "llm",
    "notetaking"
  ],
  "author": "Peter Steinberger",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/steipete/notarium-mcp.git"
  },
  "homepage": "https://github.com/steipete/notarium-mcp#readme",
  "bugs": {
    "url": "https://github.com/steipete/notarium-mcp/issues"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "dotenv": "^16.6.1",
    "env-paths": "^3.0.0",
    "pino": "^9.14.0",
    "sql.js": "^1.14.1",
    "sql.js-fts5": "^1.4.0",
    "uuid": "^14.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.20",
    "@types/sql.js": "^1.4.11",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24.0.0"
  }
}
